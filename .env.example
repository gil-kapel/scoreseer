# --- Database (matches docker-compose.yml; host port 5433 -> container 5432) ---
DATABASE_URL=postgresql+asyncpg://scoreseer:scoreseer@127.0.0.1:5433/scoreseer

# --- Claude / Anthropic (cost-tuned: Sonnet for both; search needs max_uses support) ---
ANTHROPIC_API_KEY=
PREDICT_MODEL_ID=claude-sonnet-4-6
FORMAT_MODEL_ID=claude-sonnet-4-6

# --- Sports data providers (use BOTH, free-first). Get free-tier keys: ---
#   football-data.org:  https://www.football-data.org/client/register
#   API-Football:       https://www.api-football.com/  (RapidAPI free tier)
FOOTBALL_DATA_API_KEY=
API_FOOTBALL_KEY=
SPORTS_PROVIDER_ORDER=football_data,api_football

# --- Scheduling defaults ---
PREDICTION_WINDOW_HOURS=24
PER_RUN_FIXTURE_CAP=20
# Auto predict/grade on a timer. Keep false in prod unless you want autonomous Claude spend.
SCHEDULER_ENABLED=false

# --- Runtime ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# ===========================================================================
# PRODUCTION ONLY (see DEPLOY.md). Leave blank for local dev = no auth, open app.
# ===========================================================================
# Backend API key — when set, every API route except /health requires it. The
# frontend injects it server-side; the browser never sees it. Generate:
#   openssl rand -hex 32
API_TOKEN=

# Owner-only UI gate (HTTP Basic auth on the whole frontend). Set BOTH to enable.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# Postgres credentials for docker-compose.prod.yml (use a strong password in prod).
POSTGRES_USER=scoreseer
POSTGRES_PASSWORD=
POSTGRES_DB=scoreseer

# Host port the frontend is published on (put a TLS reverse proxy in front).
WEB_PORT=3000
